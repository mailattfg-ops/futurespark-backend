datasource db {
  provider          = "postgresql"
  url               = env("AUTH_DATABASE_URL")
  directUrl         = env("AUTH_DATABASE_URL")
  schemas           = ["auth", "learning"]
}

generator client {
  provider        = "prisma-client-js"
  output          = "./client"
  previewFeatures = ["multiSchema"]
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  firstName         String?
  lastName          String?
  roleId            String?
  role              Role?             @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isActive          Boolean           @default(true)
  requiresFtlReset  Boolean           @default(false)
  lastLoginAt       DateTime?
  qualifiedPrograms String[]          @default([]) // Program IDs qualified to teach
  mentorTypes       String[]          @default(["REGULAR"]) // "REGULAR", "DEMO"
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  refreshTokens     RefreshToken[]
  mentorSchedules   MentorSchedule[]
  scheduledClasses  ScheduledClass[]  @relation("MentorClasses")
  scheduledByClasses ScheduledClass[]  @relation("ScheduledByUser")

  @@schema("auth")
}

model MentorSchedule {
  id           String   @id @default(uuid())
  mentorId     String
  mentor       User     @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  weekday      Int      // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  startTime    String   // "HH:MM" 24-hr format
  endTime      String   // auto-calculated: startTime + 90 min
  scheduleType String   @default("REGULAR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("auth")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "ADMIN", "TEACHER", etc.
  description String?
  permissions String[] @default([]) // Checked permission keys list
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("auth")
}

model RefreshToken {
  id               String         @id @default(uuid())
  token            String         @unique
  userId           String?
  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentAccountId  String?
  parentAccount    ParentAccount? @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  studentId        String?
  student          Student?       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  createdAt        DateTime       @default(now())

  @@schema("auth")
}

model ParentAccount {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String
  isActive             Boolean         @default(true)
  requiresFtlReset     Boolean         @default(false)
  profiles             ParentProfile[]
  students             Student[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  refreshTokens        RefreshToken[]
  programId            String?
  program              Program?        @relation(fields: [programId], references: [id], onDelete: SetNull)
  paymentApproved      Boolean         @default(false)
  selectedPlanType     String?         // "FULL" or "INSTALLMENT"
  paidInstallmentIds   String[]        @default([]) // IDs of paid installments

  @@schema("auth")
}

model ParentProfile {
  id              String        @id @default(uuid())
  parentAccountId String
  parentAccount   ParentAccount @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  phone           String?
  relationship    String?       // e.g. "Mother", "Father", "Guardian"
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@schema("auth")
}

model Student {
  id               String           @id @default(uuid())
  parentAccountId  String
  parentAccount    ParentAccount    @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  email            String           @unique
  passwordHash     String
  firstName        String
  lastName         String
  isActive         Boolean          @default(true)
  requiresFtlReset Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  refreshTokens    RefreshToken[]
  scheduledClasses ScheduledClass[]

  @@schema("auth")
}

model ScheduledClass {
  id              String    @id @default(uuid())
  studentId       String?
  student         Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId        String
  mentor          User      @relation("MentorClasses", fields: [mentorId], references: [id], onDelete: Cascade)
  scheduledById   String?   // Staff User ID who created this booking
  scheduledBy     User?     @relation("ScheduledByUser", fields: [scheduledById], references: [id], onDelete: SetNull)
  programId       String    // Program UUID from learning service
  sessionId       String?   // Session UUID from learning service
  startTime       DateTime
  endTime         DateTime
  status          String    @default("SCHEDULED") // "SCHEDULED", "COMPLETED", "CANCELLED"
  classType       String    @default("REGULAR")   // "REGULAR", "DEMO"
  leadId            String?   // Lead UUID if classType is DEMO
  meetingLink       String?   // Optional Google Meet / Zoom / video call URL
  rescheduleReason  String?
  rescheduleMessage String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("auth")
}

// ── Models from learning schema (read-only in auth context but mapped for relation consistency) ──

enum PlanType {
  FULL
  INSTALLMENT
  @@schema("learning")
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  ENROLLED
  LOST
  @@schema("learning")
}

model Program {
  id             String          @id @default(uuid())
  title          String
  description    String?
  level          String          @default("Beginner")
  levelColor     String          @default("purple")
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  paymentPlans   PaymentPlan[]
  leads          Lead[]
  parentAccounts ParentAccount[]

  @@schema("learning")
}

model PaymentPlan {
  id           String        @id @default(uuid())
  type         PlanType
  price        Float         @default(0.0)
  description  String?
  programId    String
  program      Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  installments Installment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([programId, type])
  @@schema("learning")
}

model Installment {
  id            String      @id @default(uuid())
  name          String
  amount        Float
  order         Int
  paymentPlanId String
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
  sessions      Session[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@schema("learning")
}

model Session {
  id            String       @id @default(uuid())
  title         String
  order         Int
  durationMin   Int          @default(60)
  slidesUrl     String?
  guideUrl      String?
  worksheetUrl  String?
  programId     String?
  program       Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  installmentId String?
  installment   Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@schema("learning")
}

model Lead {
  id          String     @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  source      String     @default("Website")
  status      LeadStatus @default(NEW)
  programId   String?
  program     Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  notes       String?
  demoClass   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@schema("learning")
}
