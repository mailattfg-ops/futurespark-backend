# Dependencies (will be reinstalled inside Docker)
node_modules/
**/node_modules/

# Build outputs (will be rebuilt inside Docker)
dist/
**/dist/

# Git
.git/
.gitignore

# Environment files — NEVER bake secrets into images
.env
**/.env
.env.*
**/.env.*

# Editor/OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Prisma generated clients (will be regenerated)
**/prisma/client/

# Logs
*.log
npm-debug.log*

# Docker files (not needed inside the image)
docker-compose.yml
docker/
