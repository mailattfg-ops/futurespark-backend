datasource db {
  provider = "postgresql"
  url      = env("INTEGRATION_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

model IntegrationConfig {
  id           String   @id @default(uuid())
  providerName String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
